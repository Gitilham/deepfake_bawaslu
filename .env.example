CI_ENVIRONMENT = production
app.baseURL = 'https://example.test/'

database.default.hostname = localhost
database.default.database = deepfake_bawaslu
database.default.username = app_user
database.default.password = change-me
database.default.DBDriver = MySQLi

# Host backend harus ditambah eksplisit pada deployment production.
ML_API_ALLOWED_HOSTS = 127.0.0.1,localhost,deepfake-api
STORE_RAW_VIDEO = false
STORE_FULL_API_RESPONSE = false
API_LOG_PAYLOAD_MAX_BYTES = 16384
STORE_FRAME_METADATA = false
