CI_ENVIRONMENT = development
app.baseURL = 'http://localhost:8080/'

database.default.hostname = localhost
database.default.database = deepfake_bawaslu
database.default.username = app_user
database.default.password = change-me
database.default.DBDriver = MySQLi
database.default.port = 3306

DEEPFAKE_API_BASE_URL = http://deepfake-backend:5000
DEEPFAKE_API_PREDICT_ENDPOINT = /predict-video
DEEPFAKE_API_HEALTH_ENDPOINT = /health
DEEPFAKE_API_DOCS_ENDPOINT = /docs
DEEPFAKE_MAX_VIDEO_MB = 500
DEEPFAKE_ALLOWED_VIDEO_FORMATS = mp4,avi,mov,mkv,webm
DEEPFAKE_API_CONNECT_TIMEOUT = 15
DEEPFAKE_API_REQUEST_TIMEOUT = 900

# Host backend harus ditambah eksplisit pada deployment production.
ML_API_ALLOWED_HOSTS = 127.0.0.1,localhost,deepfake-api
# Kompatibilitas dengan FlaskApiService dan SettingSeeder.
ML_API_BASE_URL = http://deepfake-backend:5000
ML_API_PREDICT_ENDPOINT = /predict-video
STORE_RAW_VIDEO = false
STORE_FULL_API_RESPONSE = false
API_LOG_PAYLOAD_MAX_BYTES = 16384
STORE_FRAME_METADATA = false
